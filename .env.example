# ============================================================
# FreqTrade UI — Environment Variables
# ============================================================
# Copy this file to .env and fill in production values.
#   cp .env.example .env
#
# NEVER commit .env to git — it contains secrets.
# ============================================================

# ── PostgreSQL (Orchestrator metadata DB — NOT trade data) ──
POSTGRES_DB=orchestrator
POSTGRES_USER=orchestrator
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Orchestrator (FastAPI) ──────────────────────────────────
# NOTE: ORCH_DATABASE_URL is constructed by docker-compose from the
# POSTGRES_* vars above. Do NOT set it here — it would be ignored.
ORCH_SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_STRING
ORCH_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Heartbeat: ping every 3s, 3 failures = HARD KILL
ORCH_HEARTBEAT_INTERVAL_SECONDS=3
ORCH_HEARTBEAT_MAX_FAILURES=3

# Docker (for multi-bot management)
ORCH_FT_DOCKER_IMAGE=freqtradeorg/freqtrade:stable_freqai
ORCH_FT_BASE_PORT=8080
# Host docker group GID (run: getent group docker | cut -d: -f3)
DOCKER_GID=999

# FT bot registration credentials (used by deploy.sh to register the default bot)
FT_API_USERNAME=CHANGE_ME_FT_USERNAME
FT_API_PASSWORD=CHANGE_ME_FT_PASSWORD

# ── Orchestrator Admin ────────────────────────────────────
# Admin login for the orchestrator UI
ORCH_ADMIN_USERNAME=admin
ORCH_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ── Nginx / SSL ────────────────────────────────────────────
# Domain name for SSL certificate (use server IP if no domain)
DOMAIN=your-domain-or-ip
# Email for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=admin@example.com

# ── Grafana ─────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
GF_SERVER_ROOT_URL=http://localhost/grafana/

# ── Backup ──────────────────────────────────────────────────
# How many daily backups to keep
BACKUP_RETENTION_DAYS=30

# ── AI Validation Layer ──────────────────────────────────────
# OpenRouter API key — get yours at https://openrouter.ai/keys
# This is REQUIRED when ORCH_AI_VALIDATION_ENABLED=true
# Never commit the real key to git
ORCH_AI_OPENROUTER_API_KEY=sk-or-v1-CHANGE_ME

# Enable/disable the AI validation layer (default: false for safety)
ORCH_AI_VALIDATION_ENABLED=false

# Polling interval: how often to check for new FreqAI signals (seconds)
ORCH_AI_VALIDATION_INTERVAL=60

# ── AI Model Selection ───────────────────────────────────────
# Primary models (OpenRouter model IDs)
ORCH_AI_CLAUDE_MODEL=anthropic/claude-sonnet-4-5
ORCH_AI_GROK_MODEL=x-ai/grok-4.1-fast

# Fallback models (used if primary is unavailable)
ORCH_AI_CLAUDE_FALLBACK=anthropic/claude-haiku-4-5-20251001
ORCH_AI_GROK_FALLBACK=x-ai/grok-3-mini-fast

# ── Scoring Weights (must sum to 1.0) ────────────────────────
# FreqAI gets 50% weight (it's the trading engine)
ORCH_AI_WEIGHT_FREQAI=0.50
# Claude gets 30% weight (strong reasoning)
ORCH_AI_WEIGHT_CLAUDE=0.30
# Grok gets 20% weight (fast, cheap confirmation)
ORCH_AI_WEIGHT_GROK=0.20

# ── Cost Controls ─────────────────────────────────────────────
# Maximum USD to spend per day on LLM API calls (server-side enforcement)
# At medium frequency (50 validations/day): ~$0.16/day, ~$4.80/month
ORCH_AI_MAX_DAILY_COST_USD=5.00
# Maximum validations per hour (prevents runaway costs if many bots)
ORCH_AI_MAX_VALIDATIONS_PER_HOUR=30

# ── Notifications ────────────────────────────────────────────
# Send Telegram message when Claude + Grok BOTH disagree with FreqAI
ORCH_AI_TELEGRAM_NOTIFY_DISAGREE=true

# ── Hyperopt AI Integration ───────────────────────────────────
# Enable AI suggestions before/after hyperopt runs
ORCH_AI_HYPEROPT_ENABLED=true
# Automatically send results to AI after hyperopt completes
ORCH_AI_HYPEROPT_AUTO_POST_ANALYZE=true
